#include "BluetoothSerial.h"

BluetoothSerial SerialBT;

void setup() {
  Serial.begin(9600);        // Comunicação com Arduino
  SerialBT.begin("ESP_BT");  // Bluetooth
}

void loop() {

  // Celular → ESP → Arduino
  if (SerialBT.available()) {
    String comando = SerialBT.readStringUntil('\n');
    comando.trim();

    Serial.println(comando);
  }

  // Arduino → ESP → Celular
  if (Serial.available()) {
    String resposta = Serial.readStringUntil('\n');
    SerialBT.println(resposta);
  }
}
