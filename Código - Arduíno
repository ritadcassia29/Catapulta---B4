#include <Arduino.h>
#include <Stepper.h>

const int passosPorVolta = 2048;

// Motor 1 (8, 9, 10, 11)
Stepper motor1(passosPorVolta, 8, 10, 9, 11);

// Motor 2 (4, 5, 6, 7)
Stepper motor2(passosPorVolta, 4, 6, 5, 7);

void sendData(String mensagem){
  Serial.println(mensagem);
}

void setup(){

  // Comunicação com HC-05
  Serial.begin(9600);

  // Velocidade dos motores
  motor1.setSpeed(10);
  motor2.setSpeed(10);
}

void loop(){

  // Dados recebidos do celular
  if(Serial.available()){

    String comando = Serial.readStringUntil('\n');
    comando.trim();

    // Disparo
    if(comando == "0"){

      int passosDestino = -1024;

      motor1.step(passosDestino);

      sendData("Lancamento realizado!");
    }

    // Ajuste de posição
    else{

      int passos = comando.toInt();

      motor2.step(passos);

      sendData("Lançamento preparado!");
    }
  }
}
